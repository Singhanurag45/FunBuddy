{
  "info": {
    "_postman_id": "2f322469-4fb6-4d8e-bd3e-8f04f3078b8e",
    "name": "Gamify Backend APIs",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "Collection to test all backend APIs for Gamify Learning Platform."
  },
  "item": [
    {
      "name": "1. Register User",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Anurag Singh\",\n  \"email\": \"anurag@example.com\",\n  \"password\": \"Pass@123\",\n  \"classLevel\": \"10\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/users/register",
          "host": ["{{baseUrl}}"],
          "path": ["api", "users", "register"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status code is 201', function () {",
              "    pm.response.to.have.status(201);",
              "});",
              "",
              "const body = pm.response.json();",
              "if (body && body.id) {",
              "    pm.collectionVariables.set('userId', body.id);",
              "}"
            ]
          }
        }
      ]
    },
    {
      "name": "2. Login User",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"anurag@example.com\",\n  \"password\": \"Pass@123\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/users/login",
          "host": ["{{baseUrl}}"],
          "path": ["api", "users", "login"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status code is 200', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "const body = pm.response.json();",
              "pm.test('Token exists', function () {",
              "    pm.expect(body.token).to.be.a('string').and.not.empty;",
              "});",
              "",
              "pm.collectionVariables.set('token', body.token);",
              "if (body.userId) {",
              "    pm.collectionVariables.set('userId', body.userId);",
              "}"
            ]
          }
        }
      ]
    },
    {
      "name": "3. Get All Users (Auth)",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/users",
          "host": ["{{baseUrl}}"],
          "path": ["api", "users"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status code is 200', function () {",
              "    pm.response.to.have.status(200);",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "4. Leaderboard (Auth)",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/users/leaderboard",
          "host": ["{{baseUrl}}"],
          "path": ["api", "users", "leaderboard"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status code is 200', function () {",
              "    pm.response.to.have.status(200);",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "5. Add Question (Auth)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"subject\": \"Math\",\n  \"questionText\": \"What is 2 + 2?\",\n  \"options\": [\"3\", \"4\", \"5\", \"6\"],\n  \"correctAnswer\": \"4\",\n  \"classLevel\": \"10\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/questions",
          "host": ["{{baseUrl}}"],
          "path": ["api", "questions"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status code is 201', function () {",
              "    pm.response.to.have.status(201);",
              "});",
              "",
              "const body = pm.response.json();",
              "if (body && body.id) {",
              "    pm.collectionVariables.set('questionId', body.id);",
              "}"
            ]
          }
        }
      ]
    },
    {
      "name": "6. Get Questions by Subject and Class (Auth)",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/questions?subject={{subject}}&classLevel={{classLevel}}",
          "host": ["{{baseUrl}}"],
          "path": ["api", "questions"],
          "query": [
            {
              "key": "subject",
              "value": "{{subject}}"
            },
            {
              "key": "classLevel",
              "value": "{{classLevel}}"
            }
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status code is 200', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "const body = pm.response.json();",
              "if (Array.isArray(body) && body.length > 0 && body[0].id) {",
              "    pm.collectionVariables.set('questionId', body[0].id);",
              "}"
            ]
          }
        }
      ]
    },
    {
      "name": "7. Submit Quiz (Auth)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"userId\": \"{{userId}}\",\n  \"answers\": [\n    {\n      \"questionId\": \"{{questionId}}\",\n      \"selectedAnswer\": \"4\"\n    }\n  ]\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/questions/submit",
          "host": ["{{baseUrl}}"],
          "path": ["api", "questions", "submit"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status code is 200', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "const body = pm.response.json();",
              "pm.test('Submission result has score and level fields', function () {",
              "    pm.expect(body).to.have.property('totalScore');",
              "    pm.expect(body).to.have.property('correctAnswersCount');",
              "    pm.expect(body).to.have.property('updatedPoints');",
              "    pm.expect(body).to.have.property('updatedLevel');",
              "});"
            ]
          }
        }
      ]
    }
  ],
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080"
    },
    {
      "key": "token",
      "value": ""
    },
    {
      "key": "userId",
      "value": ""
    },
    {
      "key": "questionId",
      "value": ""
    },
    {
      "key": "subject",
      "value": "Math"
    },
    {
      "key": "classLevel",
      "value": "10"
    }
  ]
}
